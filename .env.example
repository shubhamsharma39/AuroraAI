# ============================================================
# AuroraAI Environment Configuration
# Copy this file to .env and fill in your keys
# ============================================================

# --- LLM Configuration ---
# Primary LLM: Gemini 2.5 Pro (Google AI Studio)
# Secondary Fallback: Groq (llama-3.3-70b-versatile)
# Tertiary Local Backup: Ollama (mistral)
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_MODEL=mistral
OLLAMA_HOST=http://localhost:11434
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Image Generation ---
# Stability AI (FREE tier: 25 credits/month — https://platform.stability.ai)
# Leave blank to use Pollinations.ai (free, no key needed)
STABILITY_API_KEY=your_stability_api_key_here

# --- Video / GIF API ---
# Giphy API (FREE — https://developers.giphy.com/dashboard)
GIPHY_API_KEY=dc6zaTOxFJmzC

# --- Embedding Model ---
# BGE small model (local, no key needed — auto-downloaded on first run)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- App Config ---
AI_SERVICE_PORT=8000
BACKEND_PORT=5000
LOG_LEVEL=INFO
